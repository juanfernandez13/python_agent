# KB oficial do desafio (obrigatório na entrega final)
KB_URL=https://raw.githubusercontent.com/igortce/python-agent-challenge/refs/heads/main/python_agent_knowledge_base.md

# LLM - qualquer endpoint OpenAI-compatible funciona (OpenAI, Groq, OpenRouter, Together, DeepSeek, xAI, etc.)
LLM_PROVIDER=openai
LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=

# Ajustes opcionais do LLM
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=400
LLM_TIMEOUT_SECONDS=30

# Retrieval
CONTEXT_TOP_K=3
CONTEXT_MIN_SCORE=2
KB_CACHE_TTL_SECONDS=60
KB_TIMEOUT_SECONDS=15

# Memória de sessão.
# MEMORY_ENABLED=false -> desligada (NullMemoryStore).
# MEMORY_STORE="" -> em processo (InProcessMemoryStore, padrão local).
# MEMORY_STORE="redis://host:6379/0" -> Redis (usado no docker-compose).
MEMORY_ENABLED=true
MEMORY_TTL_SECONDS=900
MEMORY_MAX_TURNS=6
MEMORY_STORE=

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
